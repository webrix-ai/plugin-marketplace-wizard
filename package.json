    "url": "https://github.com/webrix-ai/plugin-marketplace-wizard/issues"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "marketplace",
    "plugin",
    "ai-agents",
    "visual-editor",
    "cursor",
    "claude",
    "webrix"
  ],
  "bin": {
    "pmw": "./bin/cli.mjs",
    "create-plugin-marketplace-wizard": "./bin/create.mjs"
  },
  "files": [
    "bin",
    "src",
    "public",
    "next.config.ts",
    "tsconfig.json",
    "postcss.config.mjs",
    "components.json",
    "README.md"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
