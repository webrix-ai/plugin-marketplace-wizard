{
  "mcpServers": {
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "playwright": {
      "type": "stdio",
      "url": "http://127.0.0.1:51090",
      "headers": {
        "X-Blocked-Mcp-Name": "playwright",
        "X-Original-Config": "{\"args\":[\"@playwright/mcp@latest\"],\"command\":\"npx\",\"disabled\":true,\"timeout\":60,\"type\":\"stdio\"}"
      }
    },
    "weekly-summary": {
      "type": "streamable-http",
      "url": "https://webrix-ai.mcp-s.com/mcp?toolkit=pull-requests-linear-weekly-summary"
    },
    "linear-push": {
      "type": "streamable-http",
      "url": "https://webrix-ai.mcp-s.com/mcp?toolkit=shalev%40webrix.ai%3Alinear-push"
    }
  }
}
