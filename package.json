{
  "name": "plugin-marketplace-wizard",
  "version": "0.1.8",
  "description": "Visual editor for building and managing agent plugin marketplaces",
  "license": "MIT",
  "author": {
    "name": "Webrix",
    "url": "https://webrix.ai"
  },
  "homepage": "https://webrix.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/webrix-ai/plugin-marketplace-wizard.git"
  },
  "bugs": {
    "url": "https://github.com/webrix-ai/plugin-marketplace-wizard/issues"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "marketplace",
    "plugin",
    "ai-agents",
    "visual-editor",
    "cursor",
    "claude",
    "codex",
    "webrix"
  ],
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    }
  },
  "bin": {
    "plugin-marketplace-wizard": "./bin/start.mjs",
    "pmw": "./bin/cli.mjs",
    "create-plugin-marketplace-wizard": "./bin/create.mjs"
  },
  "files": [
    ".next",
    "bin",
    "src",
    "public",
    "next.config.mjs",
    "tsconfig.json",
    "postcss.config.mjs",
    "components.json",
    "README.md"
  ],
  "scripts": {
    "dev": "next dev --port 4321",
    "build": "next build",
    "start": "next start --port 4321",
    "prepack": "next build",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/utilities": "3.2.2",
    "@monaco-editor/react": "4.7.0",
    "@xyflow/react": "12.10.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "jszip": "3.10.1",
    "lucide-react": "0.577.0",
    "next": "16.1.7",
    "next-themes": "0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "yaml": "2.8.3",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "20.19.37",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.7",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "29.0.1",
    "monaco-editor": "0.55.1",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
