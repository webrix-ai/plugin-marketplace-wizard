{
  "name": "plugin-marketplace-wizard",
  "version": "0.1.4",
  "description": "Visual editor for building and managing agent plugin marketplaces",
  "license": "MIT",
  "author": {
    "name": "Webrix",
    "url": "https://webrix.ai"
  },
  "homepage": "https://webrix.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/webrix-ai/plugin-marketplace-wizard.git"
  },
