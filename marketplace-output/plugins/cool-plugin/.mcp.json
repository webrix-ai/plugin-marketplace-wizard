{
  "mcpServers": {
    "jira": {
      "type": "streamable-http",
      "url": "https://run.my-mcp-s.com/mcp/mcp/jira"
    },
    "mcp-s": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp-s.wewix.net/mcp?toolkit=talbar%40wix.com%3Achannels-toolkit"
      ],
      "env": {
        "NODE_TLS_REJECT_UNAUTHORIZED": "0"
      }
    },
    "linear-push": {
      "type": "streamable-http",
      "url": "https://webrix-ai.mcp-s.com/mcp?toolkit=shalev%40webrix.ai%3Alinear-push"
    }
  }
}
